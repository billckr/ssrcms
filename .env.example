# Synaptic Signals — environment configuration
# Copy to .env and fill in values before running.
#
# Alternatively, copy synaptic.toml.example to synaptic.toml for file-based
# configuration. Environment variables (including this file) always override
# values from synaptic.toml. Set CONFIG_FILE=/path to use a custom file path.

# Required: PostgreSQL connection URL
DATABASE_URL=postgres://synaptic:password@localhost:5432/synaptic_signals

# Optional: override bind address (default: 0.0.0.0:3000)
# HOST=0.0.0.0
# PORT=3000

# Required in production: 64+ byte random secret for cookie signing
# Generate with: openssl rand -hex 32
# SECRET_KEY=change-me-in-production

# Optional: log level (default: info)
# LOG_LEVEL=debug

# Optional: enable hot reload of templates/plugins (default: false)
# DEV_MODE=true

# Optional: paths (defaults shown)
# THEMES_DIR=themes
# PLUGINS_DIR=plugins
# UPLOADS_DIR=uploads
